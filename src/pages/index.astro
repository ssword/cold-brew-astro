---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { publishedEssays, toDisplayEssays } from '../lib/essays';
import EssayCard from '../components/EssayCard.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE } from '../consts';

const { published } = publishedEssays(await getCollection('essays'));

const [featured, ...rest] = await toDisplayEssays(published, render);
---

<BaseLayout>
  <div class="home">
    <section data-hero>
      <p class="font-display text-cream">{SITE_DESCRIPTION}</p>
      <p class="font-ui text-copper">{SITE_TAGLINE}</p>
    </section>
    {featured && <EssayCard essay={featured.essay} href={featured.href} minutesRead={featured.minutesRead} variant="featured" />}
    <ul data-essay-list>
      {
        rest.map(({ essay, href, minutesRead }) => (
          <EssayCard essay={essay} href={href} minutesRead={minutesRead} variant="list-item" />
        ))
      }
    </ul>
  </div>
</BaseLayout>
