---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { publishedEssays, groupByTag, toDisplayEssays } from '../../lib/essays';
import EssayCard from '../../components/EssayCard.astro';

export async function getStaticPaths() {
  const { published } = publishedEssays(await getCollection('essays'));
  return Promise.all(
    groupByTag(published).map(async (group) => {
      const essays = await toDisplayEssays(group.essays, render);
      return { params: { tag: group.slug }, props: { tag: group.tag, essays } };
    }),
  );
}

const { tag, essays } = Astro.props;
---

<BaseLayout title={tag} description={`Essays tagged ${tag}.`}>
  <section data-tag-page class="mx-auto max-w-2xl pb-16">
    <h1 class="serif-display mb-10 text-3xl font-light tracking-tight text-cream">
      <span class="text-muted">#</span>{tag}
    </h1>
    <ul class="space-y-12 sm:space-y-14" data-essay-list>
      {
        essays.map(({ essay, href, minutesRead }) => (
          <EssayCard essay={essay} href={href} minutesRead={minutesRead} variant="list-item" />
        ))
      }
    </ul>
  </section>
</BaseLayout>
