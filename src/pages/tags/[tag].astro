---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { selectEssays, groupByTag, toDisplayEssays } from '../../lib/essays';
import EssayCard from '../../components/EssayCard.astro';

export async function getStaticPaths() {
  const { published } = selectEssays(await getCollection('essays'), {
    includeDrafts: import.meta.env.DEV,
  });
  return Promise.all(
    groupByTag(published).map(async (group) => {
      const essays = await toDisplayEssays(group.essays, render);
      return { params: { tag: group.slug }, props: { tag: group.tag, essays } };
    }),
  );
}

const { tag, essays } = Astro.props;
---

<BaseLayout title={tag} description={`Essays tagged ${tag}.`}>
  <section data-tag-page>
    <h1 class="font-display">{tag}</h1>
    <ul data-essay-list>
      {
        essays.map(({ essay, href, minutesRead }) => (
          <EssayCard essay={essay} href={href} minutesRead={minutesRead} variant="list-item" />
        ))
      }
    </ul>
  </section>
</BaseLayout>
